# ============================================================
#  TOTEM FLEXMEDIA — Configurações de Ambiente
#  Copie este arquivo para .env e preencha com suas credenciais
# ============================================================

# --- Conexão Oracle ---
ORACLE_USER=seu_usuario
ORACLE_PASSWORD=sua_senha
ORACLE_DSN=oracle.fiap.com.br:1521/ORCL
# Exemplo de DSN: host:porta/service_name
# Se usar TNS Alias: apenas o alias (ex: ORCL)

# --- Configurações do App ---
APP_NAME=Totem FlexMedia
APP_ENV=development
